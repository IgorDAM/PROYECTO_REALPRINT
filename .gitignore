# =============================================================================
# .gitignore - Excluir archivos sensibles del repositorio
# =============================================================================

# Environment variables
.env
.env.local
.env.*.local
# .env.production y .env.example SÍ se commitean (no tienen secretos)
# !.env.production
# !.env.example

# Dependencies
node_modules/
/frontend/node_modules/
/backend/.m2/

# Build output
dist/
build/
target/
*.jar
*.war
*.ear
*.class

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
*.iml
.DS_Store

# Logs
*.log
logs/
/backend/backend.log

# OS
Thumbs.db
.DS_Store

# Uploads
uploads/*
!uploads/.gitkeep

# Test coverage
coverage/
.nyc_output/
htmlcov/
test-results/

# Temporary files
tmp/
temp/
*.tmp

# Frontend
/frontend/dist/
/frontend/.next/
/frontend/out/
/frontend/build/
/frontend/.turbo/

# Backend
/backend/target/
/backend/.mvn/wrapper/
/backend/logs/

# Docker
.dockerignore
docker-compose.override.yml

# CI/CD
.gitlab-ci.yml
.travis.yml

# NPM
npm-debug.log
yarn-error.log
pnpm-debug.log

# Package managers
# package-lock.json NO debe ignorarse - es necesario para builds consistentes
yarn.lock
pnpm-lock.yaml

# Database
*.db
*.sqlite

# Backup files
*.bak
*.backup
*~

# ===================================================================
# Archivos con información sensible - NO COMMITEAR
# ===================================================================
# Nota: Si necesitas versiones con datos reales para desarrollo local,
# crea archivos con extensión .local (ejemplo: INFORME.local.md)
# y guárdalos solo en tu máquina

# Archivos de configuración con credenciales reales
**/RENDER_ENV_VARS.local.md
**/INFORME_SESION*.local.md
**/credenciales*.md
**/secrets*.md

# Archivos de notas personales que puedan contener información sensible
docs/notas/*.local.*
docs/notas/credenciales*
docs/notas/passwords*



