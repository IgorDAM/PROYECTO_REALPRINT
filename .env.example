# =============================================================================
# RealPrint Environment Variables
# =============================================================================
# IMPORTANTE: Este archivo NO debe committearse a Git
# Usar .env.example para versionamiento

# Base de Datos MySQL
DB_HOST=localhost
DB_PORT=3306
DB_NAME=realprint_db
DB_USER=root
DB_PASSWORD=root123

# JWT Security
JWT_SECRET=realprint-secret-key-dev-2026-super-larga-para-hs256-minimo-32-caracteres
JWT_EXPIRATION_MS=86400000

# Server
SERVER_PORT=8080
SERVER_CONTEXT_PATH=/api

# File Upload
MAX_FILE_SIZE=10485760
MAX_REQUEST_SIZE=12582912
UPLOAD_DIR=uploads

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Logging
LOG_LEVEL=DEBUG

# Spring Profile
SPRING_PROFILE=development

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=100
