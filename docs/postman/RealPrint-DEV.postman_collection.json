              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"servicio\": \"Serigrafía\",\n  \"descripcion\": \"Camisetas personalizadas\",\n  \"cantidad\": 50,\n  \"measurementWidthCm\": 20,\n  \"measurementHeightCm\": 25\n}"
