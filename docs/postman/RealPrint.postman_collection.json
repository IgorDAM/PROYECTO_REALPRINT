{
  "info": {
    "name": "RealPrint API",
    "description": "Colección completa de endpoints para el sistema RealPrint. Incluye autenticación, gestión de usuarios, pedidos y archivos.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "realprint-api-collection",
    "version": "1.0.0"
  },
  "item": [
    {
      "name": "Autenticación",
      "description": "Endpoints de login y autenticación",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    let body = pm.response.json();",
                  "    let token = body.token || body.accessToken || body.data?.token;",
                  "    if (token) {",
                  "        pm.environment.set('authToken', token);",
                  "        console.log('Token guardado: ' + token.substring(0, 20) + '...');",
                  "    } else {",
                  "        console.warn('No se encontró token en la respuesta:', body);",
                  "    }",
                  "} else {",
                  "    pm.environment.unset('authToken');",
                  "    console.error('Login fallido:', pm.response.code);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            }
          },
          "response": []
        }
      ]
    },
