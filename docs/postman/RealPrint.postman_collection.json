            },
            "url": {
              "raw": "{{base_url}}/usuarios",
              "host": ["{{base_url}}"],
              "path": ["usuarios"]
            }
          }
        },
        {
          "name": "Actualizar Usuario",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"username\": \"usuario_test\", \"nombre\": \"Usuario Actualizado\", \"email\": \"test.actualizado@ejemplo.com\", \"rol\": \"CLIENTE\", \"activo\": true}"
            },
            "url": {
              "raw": "{{base_url}}/usuarios/{{usuario_id}}",
              "host": ["{{base_url}}"],
              "path": ["usuarios", "{{usuario_id}}"]
            }
          }
        },
        {
          "name": "Eliminar Usuario",
          "request": {
