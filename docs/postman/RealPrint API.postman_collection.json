    {
      "name": "Autenticación",
      "description": "Endpoints de login y autenticación",
      "item": [
        {
          "name": "Login de Usuario",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    let body = pm.response.json();",
                  "    let token = body.token || body.accessToken || body.data?.token;",
                  "    if (token) {",
                  "        pm.environment.set('authToken', token);",
                  "        console.log('✅ Token guardado: ' + token.substring(0, 20) + '...');",
                  "    } else {",
                  "        console.warn('⚠️ No se encontró token en:', body);",
                  "    }",
                  "} else {",
                  "    pm.environment.unset('authToken');",
                  "    console.error('❌ Login fallido - Status:', pm.response.code);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "protocol": "http",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            }
          },
          "response": []
        }
      ]
    },
