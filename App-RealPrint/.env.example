# URL base del backend (Spring Boot)
VITE_API_URL=http://localhost:8080/api

# Timeout de cliente HTTP en milisegundos
VITE_API_TIMEOUT=10000

# true: login local (demo), false: login contra API /auth/login
VITE_USE_LOCAL_AUTH=true

# true: crear pedidos por API (con fallback local en DataContext), false: flujo local legacy
VITE_USE_PEDIDOS_SERVICE_CREATE=false

# true: actualizar pedidos por API (con fallback local en DataContext), false: flujo local legacy
VITE_USE_PEDIDOS_SERVICE_UPDATE=false

# true: eliminar pedidos por API (con fallback local en DataContext), false: flujo local legacy
VITE_USE_PEDIDOS_SERVICE_DELETE=false

# true: crear inventario por API (con fallback local), false: flujo local legacy
VITE_USE_INVENTARIO_SERVICE_CREATE=false

# true: actualizar inventario por API (con fallback local), false: flujo local legacy
VITE_USE_INVENTARIO_SERVICE_UPDATE=false

# true: eliminar inventario por API (con fallback local), false: flujo local legacy
VITE_USE_INVENTARIO_SERVICE_DELETE=false

# true: crear usuarios por API (con fallback local), false: flujo local legacy
VITE_USE_USUARIOS_SERVICE_CREATE=false

# true: actualizar usuarios por API (con fallback local), false: flujo local legacy
VITE_USE_USUARIOS_SERVICE_UPDATE=false

# true: eliminar usuarios por API (con fallback local), false: flujo local legacy
VITE_USE_USUARIOS_SERVICE_DELETE=false

